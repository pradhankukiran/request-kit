@inject ApiClientState ApiState
@implements IDisposable

<footer class="rk-statusbar" role="status">
    <div class="rk-statusbar-left">
        <span class="rk-status-pill @WorkspaceStateClass">
            <span class="rk-status-dot"></span>
            <span>@WorkspaceStateLabel</span>
        </span>
        <span class="rk-status-chip">@ApiState.CurrentWorkspaceName</span>
    </div>
    <div class="rk-statusbar-center">
        <span class="rk-status-chip">@ApiState.Collections.Count collection@(ApiState.Collections.Count == 1 ? string.Empty : "s")</span>
        <span class="rk-status-chip">@ApiState.Requests.Count request@(ApiState.Requests.Count == 1 ? string.Empty : "s")</span>
        <span class="rk-status-chip">@ApiState.History.Count history</span>
    </div>
    <div class="rk-statusbar-right">
        <span class="rk-status-chip">@(ApiState.ActiveEnvironment?.Name ?? "Default Environment")</span>
        <span class="rk-status-chip">@(ApiState.Settings.AutoSaveEnabled ? $"Auto-save {ApiState.Settings.AutoSaveIntervalSeconds}s" : "Manual save")</span>
    </div>
</footer>

@code {
    private string WorkspaceStateLabel => ApiState.IsWorkspaceSaving
        ? "Saving workspace..."
        : ApiState.IsWorkspaceDirty
            ? "Unsaved changes"
            : ApiState.LastSavedAt is null
                ? "Ready"
                : $"Saved {FormatTimestamp(ApiState.LastSavedAt.Value)}";

    private string WorkspaceStateClass => ApiState.IsWorkspaceSaving
        ? "is-saving"
        : ApiState.IsWorkspaceDirty
            ? "is-dirty"
            : "is-ready";

    private static string FormatTimestamp(DateTime timestamp)
    {
        var diff = DateTime.UtcNow - timestamp;
        if (diff.TotalMinutes < 1) return "just now";
        if (diff.TotalMinutes < 60) return $"{diff.TotalMinutes:F0}m ago";
        if (diff.TotalHours < 24) return $"{diff.TotalHours:F0}h ago";
        return timestamp.ToString("MMM d, HH:mm");
    }

    protected override void OnInitialized() => ApiState.OnChange += StateHasChanged;
    public void Dispose() => ApiState.OnChange -= StateHasChanged;
}
