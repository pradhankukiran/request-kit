@page "/workbench"
@inject AppState App
@implements IDisposable

<div class="rk-workbench">
    @switch (App.ActiveMode)
    {
        case ToolMode.ApiClient:
            <ErrorBoundary>
                <ChildContent><RequestBuilder /></ChildContent>
                <ErrorContent Context="ex">
                    <div class="rk-error-panel">API Client error: @ex.Message</div>
                </ErrorContent>
            </ErrorBoundary>
            break;
        case ToolMode.RegexBuilder:
            <ErrorBoundary>
                <ChildContent><RegexWorkbench /></ChildContent>
                <ErrorContent Context="ex">
                    <div class="rk-error-panel">Regex Builder error: @ex.Message</div>
                </ErrorContent>
            </ErrorBoundary>
            break;
        case ToolMode.DiffViewer:
            <ErrorBoundary>
                <ChildContent><DiffWorkbench /></ChildContent>
                <ErrorContent Context="ex">
                    <div class="rk-error-panel">Diff Viewer error: @ex.Message</div>
                </ErrorContent>
            </ErrorBoundary>
            break;
    }
</div>

@code {
    protected override void OnInitialized() => App.OnModeChanged += StateHasChanged;
    public void Dispose() => App.OnModeChanged -= StateHasChanged;
}
