@page "/"
@page "/home"
@inject IWorkspaceStorageService Storage
@inject ApiClientState ApiState
@inject AppState App
@inject NavigationManager Nav

<div class="rk-home">
    <div class="rk-home-header">
        <div class="rk-home-logo-large">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
                <rect width="48" height="48" rx="12" fill="url(#logo-gradient)"/>
                <path d="M26 12L16 28h9l-1 8 10-16h-9l1-8z" fill="white"/>
                <defs>
                    <linearGradient id="logo-gradient" x1="0" y1="0" x2="48" y2="48">
                        <stop stop-color="#2563EB"/>
                        <stop offset="1" stop-color="#7C3AED"/>
                    </linearGradient>
                </defs>
            </svg>
        </div>
        <h1 class="rk-home-title">RequestKit</h1>
        <p class="rk-home-subtitle">Your all-in-one developer toolkit for API testing, regex building, and text diffing.</p>
    </div>

    <div class="rk-home-features">
        <div class="rk-feature-card">
            <div class="rk-feature-icon rk-feature-icon-api">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            </div>
            <div class="rk-feature-info">
                <div class="rk-feature-name">API Client</div>
                <div class="rk-feature-desc">Send HTTP requests, inspect responses, manage collections and environments.</div>
            </div>
        </div>
        <div class="rk-feature-card">
            <div class="rk-feature-icon rk-feature-icon-regex">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="3"/><path d="M11 3v3M11 16v3M4.2 7l2.6 1.5M15.2 13.5l2.6 1.5M4.2 15l2.6-1.5M15.2 8.5l2.6-1.5"/></svg>
            </div>
            <div class="rk-feature-info">
                <div class="rk-feature-name">Regex Builder</div>
                <div class="rk-feature-desc">Build, test, and understand regular expressions with live highlighting.</div>
            </div>
        </div>
        <div class="rk-feature-card">
            <div class="rk-feature-icon rk-feature-icon-diff">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="8" height="18" rx="1"/><rect x="14" y="3" width="8" height="18" rx="1"/><path d="M6 8h0M6 12h0M6 16h0M18 8h0M18 12h0"/></svg>
            </div>
            <div class="rk-feature-info">
                <div class="rk-feature-name">Diff Viewer</div>
                <div class="rk-feature-desc">Compare text side-by-side or unified, with inline change highlighting.</div>
            </div>
        </div>
    </div>

    <div class="rk-home-content">
        <button class="rk-btn rk-btn-primary rk-btn-lg rk-home-cta" @onclick="CreateWorkspace">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            New Workspace
        </button>

        @if (!string.IsNullOrEmpty(_loadError))
        {
            <div role="alert" class="rk-error-banner">@_loadError</div>
        }

        @if (_workspaces.Count > 0)
        {
            <div class="rk-section-header">Recent Workspaces</div>
            @foreach (var ws in _workspaces)
            {
                <div class="rk-workspace-card" @key="ws.Id" @onclick="() => OpenWorkspace(ws.Id)">
                    <div class="rk-workspace-card-inner">
                        <div class="rk-workspace-icon">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V5a2 2 0 012-2h5l2 3h9a2 2 0 012 2z"/></svg>
                        </div>
                        <div>
                            <div class="rk-workspace-name">@ws.Name</div>
                            <div class="rk-workspace-meta">@ws.RequestCount requests &middot; @ws.ModifiedAt.ToString("MMM d, yyyy")</div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

@code {
    private List<WorkspaceSummary> _workspaces = [];
    private string? _loadError;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _workspaces = (await Storage.ListWorkspacesAsync()).ToList();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Failed to load workspaces: {ex.Message}");
            _loadError = "Failed to load workspaces. Storage may be unavailable.";
            _workspaces = [];
        }
    }

    private void CreateWorkspace()
    {
        ApiState.LoadWorkspace(new Workspace());
        App.SetMode(ToolMode.ApiClient);
        Nav.NavigateTo("/workbench");
    }

    private async Task OpenWorkspace(string id)
    {
        var ws = await Storage.LoadWorkspaceAsync(id);
        ApiState.LoadWorkspace(ws);
        App.SetMode(ToolMode.ApiClient);
        Nav.NavigateTo("/workbench");
    }
}
