<div class="rk-url-bar">
    <select class="rk-method-select rk-method-@(Method.ToString().ToLowerInvariant())"
            value="@Method" @onchange="OnMethodSelect">
        @foreach (var m in Enum.GetValues<HttpMethod>())
        {
            <option value="@m">@m</option>
        }
    </select>
    <input type="text" class="rk-url-input" placeholder="https://api.example.com/endpoint"
           value="@Url" @oninput="e => OnUrlChanged.InvokeAsync(e.Value?.ToString() ?? string.Empty)" />
    <button class="rk-btn rk-btn-primary rk-send-btn" @onclick="OnSend" disabled="@IsLoading">
        @(IsLoading ? "Sending..." : "Send")
    </button>
</div>

@code {
    [Parameter] public HttpMethod Method { get; set; }
    [Parameter] public string Url { get; set; } = "";
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public EventCallback<HttpMethod> OnMethodChanged { get; set; }
    [Parameter] public EventCallback<string> OnUrlChanged { get; set; }
    [Parameter] public EventCallback OnSend { get; set; }

    private void OnMethodSelect(ChangeEventArgs e)
    {
        if (Enum.TryParse<HttpMethod>(e.Value?.ToString(), out var method))
            OnMethodChanged.InvokeAsync(method);
    }
}
