@inject RegexState State

<div class="rk-explanation-panel">
    @if (State.Explanation.Count == 0)
    {
        <div class="rk-match-empty">Enter a pattern to see its explanation.</div>
    }
    else
    {
        <table class="rk-explanation-table">
            <thead>
                <tr>
                    <th>Token</th>
                    <th>Description</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < State.Explanation.Count; i++)
                {
                    var part = State.Explanation[i];
                    <tr @key="@($"{i}-{part.Token}")">
                        <td><code class="rk-explanation-token">@part.Token</code></td>
                        <td class="rk-explanation-desc">@part.Description</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
