@using RequestKit.Core.Data
@inject RegexState State

<div class="rk-common-patterns">
    @foreach (var category in CommonPatternsLibrary.Categories)
    {
        <div class="rk-pattern-category" @key="category">
            <div class="rk-section-header">@category</div>
            @foreach (var p in CommonPatternsLibrary.GetByCategory(category))
            {
                <div class="rk-pattern-card" @key="p.Name" @onclick="() => SelectPattern(p)">
                    <div class="rk-pattern-card-name">@p.Name</div>
                    <div class="rk-pattern-card-sample">@p.SampleMatch</div>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public EventCallback<CommonPattern> OnPatternSelected { get; set; }

    private async Task SelectPattern(CommonPattern pattern)
    {
        State.SetPattern(pattern.Pattern);
        State.SetTestString(pattern.SampleMatch);
        await OnPatternSelected.InvokeAsync(pattern);
    }
}
